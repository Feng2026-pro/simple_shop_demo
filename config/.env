# API 根地址（simple_shop_demo 默认 Flask 端口）
BASE_URL=http://127.0.0.1:5000

# 下单类用例默认商品 ID（新建商品后请改为实际 id，或清空 shop.db 后从 1 开始）
TEST_PRODUCT_ID=1

# ---------------------------------------------------------------------------
# 前置依赖：simple_shop_demo 无登录/鉴权接口，无需 LOGIN_* / dependencies.yaml
# CSV 用例「前置依赖」列填「无」即可
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# DB 断言（JSON plan 中 db_assert；默认关闭）
# 说明：simple_shop_demo 使用 SQLite（simple_shop_demo/shop.db），
#       api-test-runner 的 db_assert 当前为 MySQL 连接；启用前请确认库类型与连接信息
# ---------------------------------------------------------------------------
DB_ASSERT_ENABLED=false
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shop
DB_USER=test_user
DB_PASS=your_db_password_here
DB_CHARSET=utf8mb4
